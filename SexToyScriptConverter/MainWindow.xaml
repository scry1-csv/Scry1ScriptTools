<Window
    x:Class="SexToyScriptConverter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SexToyScriptConverter"
    xmlns:localControl="clr-namespace:Core.Control;assembly=Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">
        <localControl:MediaPlayerControl x:Name="MediaPlayer" Grid.Row="0" />
        <DockPanel DockPanel.Dock="Top">
            <Button
                Margin="20,10,10,10"
                Padding="8,3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="OpenButton_Click"
                Content="開く..." />
            <TextBlock
                Margin="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                ドラッグ＆ドロップでもファイルを開けます。
            </TextBlock>
            <TextBlock Margin="20,10" HorizontalAlignment="Right">
                右クリック＋ドラッグ：移動<LineBreak />
                マウスホイール：ズーム</TextBlock>
        </DockPanel>


    </StackPanel>
</Window>
