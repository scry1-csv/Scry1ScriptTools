<Window
    x:Class="SexToyScriptViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SexToyScriptViewer"
    xmlns:localControl="clr-namespace:Scry1ScriptTools.Core.Control;assembly=Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:vm="clr-namespace:SexToyScriptViewer"
    Title="SexToyScriptViewer"
    Width="600"
    Height="400"
    AllowDrop="True"
    Drop="Window_Drop"
    PreviewDragOver="Window_PreviewDragOver"
    ResizeMode="CanResizeWithGrip"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Core の MediaPlayerControl を使用する -->
        <localControl:MediaPlayerControl
            x:Name="MediaPlayer"
            Grid.Row="0" />

        <DockPanel Grid.Row="1">

            <DockPanel DockPanel.Dock="Top">
                <Button
                    Margin="20,10,10,10"
                    Padding="8,3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="OpenButton_Click"
                    Content="開く..." />
                <TextBlock
                    Margin="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    ドラッグ＆ドロップでもファイルを開けます。
                </TextBlock>
                <TextBlock Margin="20,10" HorizontalAlignment="Right">
                    右クリック＋ドラッグ：移動<LineBreak />
                    マウスホイール：ズーム</TextBlock>
            </DockPanel>

            <StackPanel
                HorizontalAlignment="Center"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <RadioButton
                    x:Name="RadioButton_HHMMSS"
                    Margin="0,0,10,0"
                    Checked="RadioButton_HHMMSS_Checked">
                    時分秒表示
                </RadioButton>
                <RadioButton Margin="0,0,0,0" Checked="RadioButton_InternalTime_Checked">内部値表示</RadioButton>
            </StackPanel>


            <Grid x:Name="ChartsPanel" />

        </DockPanel>
    </Grid>
</Window>
